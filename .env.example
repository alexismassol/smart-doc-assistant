# ── LLM PROVIDER ─────────────────────────────────────────────────────────────
# Valeurs : "ollama" | "mistral" | "anthropic"
LLM_PROVIDER=ollama

# Ollama (local, gratuit — mode dev par défaut)
OLLAMA_BASE_URL=http://localhost:11434
# Modèles disponibles (ollama pull <nom>) :
#   mistral        — 4.4 GB — meilleure qualité, ~30-60s/réponse sur CPU
#   phi3:mini      — 2.2 GB — rapide, ~10-20s sur CPU (recommandé sans GPU)
#   llama3.2:3b    — 1.9 GB — très rapide, bon pour tester
OLLAMA_MODEL=mistral

# Mistral API (prod public)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Anthropic Claude (alternatif)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ── EMBEDDINGS ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_PROVIDER=ollama

# ── CHROMADB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=smart_docs

# ── BACKEND ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# ── AGENT ─────────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.4
MEMORY_WINDOW=5

# ── HISTORIQUE PERSISTANT SQLite ──────────────────────────────────────────────
HISTORY_DB_PATH=./data/history.db
